VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Next.js server-side rendering. Do not expose these in client code.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
REVALIDATE_SECRET=
SECURITY_HASH_SECRET=
CRON_SECRET=

# Optional bot verification. When set, the booking API requires a valid token.
TURNSTILE_SECRET_KEY=

# Optional acquisition/conversion analytics. Example: GTM-XXXXXXX.
# Google Consent Mode starts with analytics/ad storage denied.
NEXT_PUBLIC_GTM_ID=

# Cloudinary CMS image uploads. Do not expose these in client code.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Booking notifications. Keep all secret values in .env.local or Vercel only.
RESEND_API_KEY=
BOOKING_EMAIL_FROM=
BOOKING_EMAIL_REPLY_TO=
DISCORD_BOOKING_WEBHOOK_URL=
DISCORD_BOOKING_ROLE_ID=
BOOKING_NOTIFICATION_TO=
NOTIFICATION_ENCRYPTION_KEY=
RESEND_WEBHOOK_SECRET=
